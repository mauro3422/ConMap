/**
 * STYLES: Conceptual Map Visual System
 */

:root {
  --bg-color: #010409;
  --canvas-bg: #0d1117;
  --text-main: #e6edf3;
  --accent-gold: #f5c842;
  --accent-teal: #42e5c8;
  --accent-green: #5dde8c;
  --border-muted: #30363d;
  --color-muted: #6b7a99;
  --color-relation: #556080;
  --color-footer: #484f58;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background-color: var(--bg-color);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  margin: 0;
  padding: 20px 12px 100px;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  overflow-x: hidden;
}

.header { text-align: center; margin-bottom: 40px; }

.sub-title-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}

.book-icon {
  width: 20px;
  height: 20px;
  color: var(--accent-gold);
  opacity: 0.85;
  flex-shrink: 0;
}

.sub-title {
  color: var(--color-muted);
  font-size: 0.9rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  font-weight: 700;
  margin: 0;
}

.subject-badge {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-gold);
  background: rgba(245, 200, 66, 0.08);
  border: 1px solid rgba(245, 200, 66, 0.25);
  border-radius: 20px;
  padding: 3px 12px;
}

h1 {
  font-family: 'Crimson Pro', Georgia, serif;
  color: var(--accent-gold);
  font-size: 4rem;
  font-weight: 700;
  text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  line-height: 1.1;
}

.legend {
  display: flex;
  justify-content: center;
  gap: 40px;
  margin: 40px 0 60px;
  flex-wrap: wrap;
  background: rgba(13, 17, 23, 0.8);
  padding: 20px 50px;
  border-radius: 60px;
  border: 1px solid var(--border-muted);
  font-size: 1.2rem;
  font-weight: 700;
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.legend-item { display: flex; align-items: center; gap: 12px; transition: opacity 0.3s; }
.legend-item:hover { opacity: 0.8; cursor: default; }
.ld { width: 16px; height: 16px; border-radius: 50%; flex-shrink: 0; }
.ld-gold { background: var(--accent-gold); box-shadow: 0 0 10px var(--accent-gold); }
.ld-teal { background: var(--accent-teal); box-shadow: 0 0 10px var(--accent-teal); }
.ld-green { background: var(--accent-green); box-shadow: 0 0 10px var(--accent-green); }
.ld-red { background: #ff7b72; box-shadow: 0 0 10px #ff7b72; }
.dash-line { border-top: 3px dashed var(--color-relation); width: 30px; display: inline-block; }

.canvas-wrap {
  width: 100%;
  max-width: 1800px;
  margin: 40px auto;
  background: var(--canvas-bg);
  border: none;
  position: relative;
  box-shadow: 0 40px 100px rgba(0,0,0,0.8);
  border-radius: 40px;
  overflow: hidden;
}

svg { display: block; width: 100%; height: auto; transition: opacity 0.25s ease; }

/* ─── Book Button & Topic Dropdown ───────────────────────────── */
.book-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  border-radius: 8px;
  color: var(--accent-gold);
  transition: background 0.2s, transform 0.2s;
  display: flex;
  align-items: center;
}
.book-btn:hover  { background: rgba(245,200,66,0.12); transform: scale(1.1); }
.book-btn.open   { background: rgba(245,200,66,0.15); }

.sub-title-wrap  { position: relative; }

/* Topic Dropdown — Contenedor con Scroll */
.topic-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  width: 320px;
  background: #0d1117; /* Fondo sólido para evitar transparencia sucia */
  border: 1px solid var(--border-color);
  border-radius: 12px;
  margin-top: 12px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.8);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 9999; /* Máximo nivel */
  overflow: hidden;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
}

.topic-dropdown.open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

/* ─── Modales Premium ─── */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.open {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: var(--bg-card);
  width: 90%;
  max-width: 450px;
  border-radius: 20px;
  border: 1px solid var(--border-color);
  box-shadow: 0 25px 60px rgba(0,0,0,0.9);
  padding: 30px;
  transform: scale(0.9);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.modal-overlay.open .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
}

.modal-header h3 { font-size: 1.4rem; color: #fff; }

.modal-body label {
  display: block;
  margin-bottom: 8px;
  font-size: 0.9rem;
  color: var(--text-dim);
}

.modal-body input {
  width: 100%;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border-color);
  padding: 12px 16px;
  border-radius: 10px;
  color: #fff;
  margin-bottom: 20px;
  font-size: 1rem;
}

.modal-body input:focus {
  border-color: #5dde8c;
  outline: none;
  background: rgba(93, 222, 140, 0.05);
}

.modal-footer {
  display: flex;
  gap: 12px;
  justify-content: flex-end;
  margin-top: 10px;
}

.btn-primary {
  background: #5dde8c;
  color: #0d1117;
  border: none;
  padding: 12px 24px;
  border-radius: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-secondary {
  background: rgba(255,255,255,0.05);
  color: var(--text-dim);
  border: 1px solid var(--border-color);
  padding: 12px 24px;
  border-radius: 12px;
  font-weight: 600;
  cursor: pointer;
}

.btn-primary:hover { transform: translateY(-2px); filter: brightness(1.1); }
.close-btn { background: none; border: none; color: var(--text-dim); font-size: 1.5rem; cursor: pointer; }

.topic-items-container {
  overflow-y: auto;
  flex: 1;
}

.topic-dropdown-label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  padding: 6px 12px 10px;
  display: block;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-dim);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: help;
  position: relative; /* Para el tooltip */
}

/* Tooltip Premium */
.legend-item::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: 150%;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: rgba(22, 27, 34, 0.95);
  color: #fff;
  padding: 8px 14px;
  border-radius: 8px;
  font-size: 0.8rem;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  border: 1px solid var(--border-color);
  backdrop-filter: blur(8px);
  z-index: 100;
}

.legend-item:hover::after {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

/* Acciones en el Dropdown */
.dropdown-action {
  padding: 15px;
  border-top: 1px solid var(--border-color);
  display: flex;
  justify-content: center;
}

.add-topic-btn {
  background: rgba(93, 222, 140, 0.1);
  color: #5dde8c;
  border: 1px dashed #5dde8c;
  padding: 8px 20px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
}

.add-topic-btn:hover {
  background: #5dde8c;
  color: #0d1117;
  transform: translateY(-2px);
}

.topic-dropdown-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 16px;
  margin: 6px 12px;
  border-radius: 14px;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.topic-dropdown-item:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.15);
  transform: translateX(4px);
}

.delete-topic-btn {
  background: rgba(255, 77, 77, 0.15) !important;
  border: 1px solid rgba(255, 77, 77, 0.3) !important;
  font-size: 1.2rem;
  cursor: pointer;
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4d;
  flex-shrink: 0;
  order: -1; /* MOVER A LA IZQUIERDA */
  transition: all 0.2s ease;
}

.delete-topic-btn:hover {
  background: #ff4d4d !important;
  color: #fff;
  transform: scale(1.1) rotate(10deg);
  box-shadow: 0 4px 15px rgba(255, 77, 77, 0.4);
}

.topic-item-check {
  display: none;
  color: #f5c842;
  font-weight: 800;
  margin-left: auto;
  margin-right: 8px;
}

.topic-dropdown-item.active .topic-item-check {
  display: inline-block;
}

/* Scrollbar en el Dropdown */
.topic-items-container::-webkit-scrollbar {
  width: 6px;
}

.topic-items-container::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.1);
  border-radius: 10px;
}

.topic-dropdown-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 6px 10px; }

/* ─── Zoom Controls ─────────────────────────────────────────── */
.zoom-controls {
  position: absolute;
  bottom: 24px;
  right: 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  background: rgba(13, 17, 23, 0.8);
  backdrop-filter: blur(12px);
  padding: 8px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  z-index: 100;
}

.zoom-controls button {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  font-size: 1.2rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.zoom-controls button:hover {
  background: rgba(255, 255, 255, 0.1);
  color: var(--accent-gold);
  border-color: rgba(245, 200, 66, 0.3);
  transform: translateY(-2px);
}

.zoom-controls button:active {
  transform: scale(0.95);
}

#zoomReset {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.05em;
}

/* ─── View Modes ────────────────────────────────────────────── */
.canvas-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  min-height: 80vh;
  padding-bottom: 100px;
}

/* Modo Infografía (Default) */
body.mode-infographic .canvas-wrap {
  overflow: visible;
  cursor: default;
}

body.mode-infographic svg {
  margin: 0 auto;
  box-shadow: 0 10px 50px rgba(0,0,0,0.3);
  background: rgba(255,255,255,0.02);
  border-radius: 20px;
  max-width: 95%;
}

/* Modo Interactivo */
body.mode-interactive {
  user-select: none;
  -webkit-user-select: none;
}

body.mode-interactive .canvas-wrap {
  overflow: hidden;
  cursor: grab;
  height: 80vh; /* Altura fija para el viewport de zoom */
}

#viewport {
  will-change: transform; /* Forzar aceleración por GPU */
}

body.mode-interactive .canvas-wrap:active { cursor: grabbing; }

body.mode-interactive svg {
  box-shadow: none;
  background: none;
  max-width: none;
}

/* Toggle Button */
.view-toggle-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 100px;
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  margin-left: auto;
}

.view-toggle-btn:hover {
  background: rgba(255,255,255,0.1);
  border-color: var(--accent-gold);
}

.view-toggle-btn.active {
  background: rgba(245, 200, 66, 0.1);
  border-color: var(--accent-gold);
  color: var(--accent-gold);
}

.legend {
  display: flex;
  align-items: center; /* Alinear con el nuevo botón */
  flex-wrap: wrap;
}


.node-rect { 
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
  cursor: pointer; 
  transform-origin: center;
  transform-box: fill-box;
}

.node-group {
  cursor: pointer;
  pointer-events: all;
}

.node-group:hover .node-rect { 
  filter: brightness(1.3) saturate(1.4) drop-shadow(0 0 20px var(--accent-gold)); 
  transform: scale(1.05); 
}

.node-group text {
  pointer-events: none;
  transition: all 0.3s ease;
}

.node-group:hover text {
  fill: var(--text-main);
}

.footer-note {
  margin-top: 80px;
  color: var(--color-footer);
  font-size: 1rem;
  font-style: italic;
  text-align: center;
  max-width: 600px;
  line-height: 1.6;
}

/* ─── Checkboxes del Modal ─── */
.modal-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 10px;
  margin-bottom: 25px;
}

.check-container {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  font-size: 0.95rem;
  color: #fff;
  transition: all 0.2s ease;
}

.check-container input { display: none; }

.checkmark {
  width: 22px;
  height: 22px;
  border-radius: 6px;
  border: 2px solid var(--border-muted);
  display: inline-block;
  position: relative;
}

.check-container input:checked + .checkmark::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-weight: 900;
  font-size: 14px;
}

.checkmark.gold { border-color: var(--accent-gold); }
.check-container input:checked + .checkmark.gold { background: var(--accent-gold); color: #000; }

.checkmark.teal { border-color: var(--accent-teal); }
.check-container input:checked + .checkmark.teal { background: var(--accent-teal); color: #000; }

.checkmark.green { border-color: var(--accent-green); }
.check-container input:checked + .checkmark.green { background: var(--accent-green); color: #000; }

.theme-input-wrap {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 5px;
}

.theme-input {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(255,255,255,0.02);
  padding: 5px 12px;
  border-radius: 8px;
  border: 1px solid var(--border-muted);
}

.theme-input input {
  background: none !important;
  border: none !important;
  margin-bottom: 0 !important;
  padding: 8px 0 !important;
}

.legend-content {
  display: flex;
  gap: 30px;
  align-items: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
}
